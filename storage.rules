rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Fotos de perfil: qualquer usuário autenticado pode visualizar,
    // apenas o dono pode enviar/substituir a própria foto.
    match /profile_photos/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Imagens de publicações: leitura para autenticados, escrita apenas
    // na própria pasta do usuário autor.
    match /publication_photos/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
                   && request.resource.size < 8 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
